#!/bin/bash
#
# InjectionRadar CLI Wrapper
# Aktiviert automatisch das venv und startet das CLI
#

# Löse Symlinks auf um den echten Pfad zu finden
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

VENV_DIR="$SCRIPT_DIR/.venv"

# Prüfe ob venv existiert
if [ ! -d "$VENV_DIR" ]; then
    echo "Fehler: Virtual Environment nicht gefunden."
    echo "Bitte führe zuerst aus: cd $SCRIPT_DIR && ./install.sh"
    exit 1
fi

# Aktiviere venv und starte CLI
source "$VENV_DIR/bin/activate"
exec injection-radar "$@"
