# Prompt Injection Shield - Scraper Sandbox (Subsystem)
FROM python:3.11-slim

WORKDIR /app

# System dependencies für Playwright
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    gnupg \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Create non-root user BEFORE installing Playwright
RUN useradd -m -u 1000 scraper

# Playwright Browser-Pfad für alle User zugänglich
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright
RUN mkdir -p /opt/playwright && chmod 777 /opt/playwright

# Install Playwright browsers (als root, aber in shared directory)
RUN playwright install chromium && playwright install-deps chromium

# Application code - nur Scraper-relevante Module
COPY src/scraper/ ./src/scraper/
COPY src/llm/ ./src/llm/
COPY src/core/ ./src/core/
COPY src/analysis/ ./src/analysis/
COPY src/__init__.py ./src/

# Ownership setzen und zu non-root User wechseln
RUN chown -R scraper:scraper /app
USER scraper

# Kein exposed Port - kommuniziert nur über DB/Redis

# Start Scraper Worker
CMD ["python", "-m", "src.scraper.worker"]
