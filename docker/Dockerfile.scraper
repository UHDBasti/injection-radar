# Prompt Injection Shield - Scraper Sandbox (Subsystem)
FROM python:3.11-slim

WORKDIR /app

# System dependencies für Playwright
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    gnupg \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers
RUN playwright install chromium

# Application code - nur Scraper-relevante Module
COPY src/scraper/ ./src/scraper/
COPY src/llm/ ./src/llm/
COPY src/core/ ./src/core/

# Create non-root user mit eingeschränkten Rechten
RUN useradd -m -u 1000 scraper && \
    chown -R scraper:scraper /app
USER scraper

# Kein exposed Port - kommuniziert nur über DB/Redis

# Start Scraper Worker
CMD ["python", "-m", "src.scraper.worker"]
