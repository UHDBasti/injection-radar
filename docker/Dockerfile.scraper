# Prompt Injection Shield - Scraper Sandbox (Subsystem)

# Stage 1: Builder - install Python dependencies
FROM python:3.11-slim@sha256:0b23cfb7425d065008b778022a17b1551c82f8b4866ee5a7a200084b7e2eafbf AS builder

WORKDIR /build

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# Stage 2: Final - minimal runtime image with Playwright
FROM python:3.11-slim@sha256:0b23cfb7425d065008b778022a17b1551c82f8b4866ee5a7a200084b7e2eafbf

WORKDIR /app

# System dependencies for Playwright/Chromium (runtime deps - must stay in final image)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed Python packages from builder
COPY --from=builder /install /usr/local

# Create non-root user BEFORE installing Playwright
RUN useradd -m -u 1000 scraper

# Playwright Browser-Pfad with proper permissions (no world-writable)
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright
RUN mkdir -p /opt/playwright && chown scraper:scraper /opt/playwright && chmod 755 /opt/playwright

# Install Playwright browsers as scraper user
USER scraper
RUN playwright install chromium
USER root
RUN playwright install-deps chromium && rm -rf /var/lib/apt/lists/*

# Application code - nur Scraper-relevante Module
COPY src/scraper/ ./src/scraper/
COPY src/llm/ ./src/llm/
COPY src/core/ ./src/core/
COPY src/analysis/ ./src/analysis/
COPY src/__init__.py ./src/

# Ownership setzen und zu non-root User wechseln
RUN chown -R scraper:scraper /app
USER scraper

# Unbuffered output für Docker logs
ENV PYTHONUNBUFFERED=1

# Kein exposed Port - kommuniziert nur über DB/Redis

# Start Scraper Worker
CMD ["python", "-m", "src.scraper.worker"]
